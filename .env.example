# Non-secret Radar-Sat R2 settings. Keep object credentials in Keychain when possible.
RADARSAT_R2_ACCOUNT_ID=52ff7b6afb8d56ad477b6d61ff96157e
RADARSAT_R2_BUCKET=radar-sat
RADARSAT_R2_PUBLIC_BASE_URL=https://pub-2cb8162da84b4c1eb0e445844f2a89a3.r2.dev

# Dedicated bucket guardrails. This keeps Radar-Sat well below the account's
# account-wide 10 GB-month free allocation when other buckets are also present.
RADARSAT_R2_WARN_BYTES=4000000000
RADARSAT_R2_MAX_BYTES=5000000000

# Optional runtime tuning.
RADARSAT_INGEST_HOURS=3
RADARSAT_SPOOL_ROOT=${HOME}/.local/share/radar-sat/spool/eccc
RADARSAT_SPOOL_MODE=auto
RADARSAT_SPOOL_INGEST_HOURS=12
RADARSAT_RAW_RETENTION_HOURS=3
RADARSAT_RAW_SAT_ENABLED=1
RADARSAT_RAW_SAT_CACHE_ROOT=var/cache/raw-satellite
# Hard cap for transient compressed GOES/Himawari downloads (about 0.9 GB).
RADARSAT_RAW_SAT_MAX_BYTES=900000000
# Dedicated genuine ten-minute GOES-18 source shared by Radar-Sat and WestWX.
# Enabling it transfers roughly 43-45 GB/day at current object sizes.
RADARSAT_WESTWX_SATELLITE_ENABLED=0
RADARSAT_WESTWX_SATELLITE_CACHE_ROOT=var/cache/westwx-satellite
# Allow one live scan plus one bounded catch-up scan after a long broad cycle.
RADARSAT_WESTWX_SATELLITE_HOURS=3
RADARSAT_WESTWX_SATELLITE_MAX_FRAMES=2
RADARSAT_WESTWX_SATELLITE_MAX_DOWNLOAD_GB=0.8
RADARSAT_WESTWX_SATELLITE_MAX_SOURCE_MB=400
RADARSAT_NATIVE_BC_SATELLITE_ENABLED=1
RADARSAT_NATIVE_BC_SATELLITE_HOURS=3
RADARSAT_NATIVE_BC_SATELLITE_MAX_FRAMES=1
RADARSAT_NATIVE_BC_SATELLITE_MAX_DOWNLOAD_GB=0.7
RADARSAT_NATIVE_BC_SATELLITE_MAX_SOURCE_MB=700
# Ten-minute GOES-18 smoke detection and total-lightning overlays. NOAA source
# files are transient and deleted as soon as each compact PNG has been rendered.
RADARSAT_GOES_HAZARDS_ENABLED=1
# Hard cap applied independently to each transient ADPF or GLM object.
RADARSAT_GOES_HAZARD_MAX_BYTES=100000000
# Local BC Hydro watershed boundary source used for the static map overlay.
RADARSAT_BCH_WATERSHEDS=${HOME}/projects/fcstGraphics/data/bc_watersheds/bch/AllWatershedsUTM.shp
# These thresholds apply to processed output, not the separate native spool.
RADARSAT_LOCAL_WARN_BYTES=8000000000
RADARSAT_LOCAL_MAX_BYTES=10000000000
