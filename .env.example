# Non-secret Radar-Sat R2 settings. Keep object credentials in Keychain when possible.
RADARSAT_R2_ACCOUNT_ID=52ff7b6afb8d56ad477b6d61ff96157e
RADARSAT_R2_BUCKET=radar-sat
RADARSAT_R2_PUBLIC_BASE_URL=https://pub-2cb8162da84b4c1eb0e445844f2a89a3.r2.dev

# Dedicated bucket guardrails. This keeps Radar-Sat well below the account's
# account-wide 10 GB-month free allocation when other buckets are also present.
RADARSAT_R2_WARN_BYTES=4000000000
RADARSAT_R2_MAX_BYTES=5000000000

# Optional runtime tuning.
RADARSAT_INGEST_HOURS=3
RADARSAT_SPOOL_ROOT=${HOME}/.local/share/radar-sat/spool/eccc
RADARSAT_SPOOL_MODE=auto
RADARSAT_SPOOL_INGEST_HOURS=12
RADARSAT_RAW_RETENTION_HOURS=3
# These thresholds apply to processed output, not the separate native spool.
RADARSAT_LOCAL_WARN_BYTES=8000000000
RADARSAT_LOCAL_MAX_BYTES=10000000000
